FROM maven:3.9.9-eclipse-temurin-17

WORKDIR /app

ARG USER_ID=1000
ARG GROUP_ID=1000

ENV TZ=America/Santiago
ENV MAVEN_CONFIG=

RUN apt-get update && \
    apt-get install -y curl make telnet && \
    rm -rf /var/lib/apt/lists/*

COPY pom.xml ./

# Cache Maven dependencies separately so source-only changes reuse this layer.
RUN --mount=type=cache,target=/root/.m2 mvn dependency:go-offline

COPY src src

RUN --mount=type=cache,target=/root/.m2 mvn -DskipTests compile
